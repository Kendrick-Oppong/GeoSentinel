{
  "name": "temp-turbo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prisma:generate": "npm run prisma:generate --workspace @geosentinel/server",
    "prisma:migrate": "npm run prisma:migrate --workspace @geosentinel/server",
    "prisma:studio": "npm run prisma:studio --workspace @geosentinel/server",
    "db:up": "docker compose up -d postgis",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgis",
    "dev:server": "npm run dev --workspace @geosentinel/server",
    "dev:web": "npm run dev --workspace @geosentinel/web",
    "dev:simulator": "npm run dev --workspace @geosentinel/simulator",
    "build:server": "npm run build --workspace @geosentinel/server",
    "build:web": "npm run build --workspace @geosentinel/web",
    "build:simulator": "npm run build --workspace @geosentinel/simulator",
    "start:server": "npm run start --workspace @geosentinel/server",
    "start:web": "npm run start --workspace @geosentinel/web",
    "start:simulator": "npm run start --workspace @geosentinel/simulator",
    "start:all": "npm run start:server && npm run start:web && npm run start:simulator"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.7",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
